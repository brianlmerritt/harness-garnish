#!/usr/bin/env bash
set -euo pipefail

repository_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
cd "$repository_root"

test_root="$(mktemp -d)"
cleanup() {
  rm -rf -- "$test_root"
}
trap cleanup EXIT

acceptance_step="startup"
report_error() {
  local status="$?"
  trap - ERR
  printf 'error: packaged CLI acceptance failed during %s (exit=%s)\n' \
    "$acceptance_step" "$status" >&2
  exit "$status"
}
trap report_error ERR

quota_free_env=(
  env
  -u OPENAI_API_KEY
  -u ANTHROPIC_API_KEY
  -u ANTHROPIC_AUTH_TOKEN
  -u GARNISH_DATA_DIR
  -u GARNISH_REAL_API_PROVIDER
  -u GARNISH_REAL_API_MODEL
  -u GARNISH_REAL_API_SECRET_REFERENCE
  -u GARNISH_ACKNOWLEDGE_PAID_API
  -u GARNISH_ACKNOWLEDGE_PAID_API_PATCH
  -u GARNISH_API_SMOKE_RECEIPT_DIR
  -u GARNISH_REAL_CODEX_REMAINING_PERCENT
  -u GARNISH_ACKNOWLEDGE_CODEX_SUBSCRIPTION
  -u GARNISH_CODEX_SMOKE_RECEIPT_DIR
  -u GARNISH_REAL_DOCKER_IMAGE
  -u GARNISH_REAL_PODMAN_IMAGE
  GIT_CONFIG_NOSYSTEM=1
  GIT_CONFIG_GLOBAL=/dev/null
)

fixture_git=(
  env
  GIT_CONFIG_NOSYSTEM=1
  GIT_CONFIG_GLOBAL=/dev/null
  git
)

echo "PACKAGED CLI ACCEPTANCE TEST"
echo "provider credentials and live-test acknowledgements: removed from the package and test processes"
echo "network/provider use: none; deterministic fake task only"

acceptance_step="native release packaging"
GARNISH_RELEASE_OUTPUT_DIR="$test_root/packages" \
GARNISH_PACKAGE_ALLOW_DIRTY='I_ACCEPT_TESTING_AN_UNCOMMITTED_PACKAGE' \
  "${quota_free_env[@]}" ./scripts/package-release

first_archive_checksum="$(awk 'NR == 1 {print $1}' "$test_root/packages/SHA256SUMS")"
acceptance_step="repeated-package determinism check"
GARNISH_RELEASE_OUTPUT_DIR="$test_root/packages" \
GARNISH_PACKAGE_ALLOW_DIRTY='I_ACCEPT_TESTING_AN_UNCOMMITTED_PACKAGE' \
  "${quota_free_env[@]}" ./scripts/package-release >/dev/null
second_archive_checksum="$(awk 'NR == 1 {print $1}' "$test_root/packages/SHA256SUMS")"
if [[ -z "$first_archive_checksum" || "$first_archive_checksum" != "$second_archive_checksum" ]]; then
  echo "error: repeated native packaging was not deterministic" >&2
  exit 1
fi

acceptance_step="archive discovery"
mapfile_compatible_archives=()
while IFS= read -r archive; do
  mapfile_compatible_archives+=("$archive")
done < <(find "$test_root/packages" -maxdepth 1 -type f -name 'harness-garnish-*.tar.gz' -print | LC_ALL=C sort)

if [[ "${#mapfile_compatible_archives[@]}" != "1" ]]; then
  echo "error: package test expected exactly one native archive" >&2
  exit 1
fi
archive_path="${mapfile_compatible_archives[0]}"

acceptance_step="archive checksum verification"
(
  cd "$test_root/packages"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum -c SHA256SUMS
  else
    shasum -a 256 -c SHA256SUMS
  fi
)

acceptance_step="archive extraction and content validation"
mkdir -p "$test_root/extracted"
tar -xzf "$archive_path" -C "$test_root/extracted"
package_root="$(find "$test_root/extracted" -mindepth 1 -maxdepth 1 -type d -print)"
if [[ -z "$package_root" || "$(printf '%s\n' "$package_root" | wc -l | tr -d ' ')" != "1" ]]; then
  echo "error: package test expected exactly one extracted package directory" >&2
  exit 1
fi

packaged_binary="$package_root/bin/garnish"
[[ -x "$packaged_binary" ]]
[[ -f "$package_root/README.md" ]]
[[ -f "$package_root/LICENSE" ]]
[[ -f "$package_root/VERSION" ]]
[[ -f "$package_root/MANIFEST.txt" ]]
[[ -f "$package_root/docs/installation.md" ]]
[[ -f "$package_root/docs/operator-guide.md" ]]
[[ -z "$(find "$package_root" -type l -print -quit)" ]]

acceptance_step="packaged executable version and help checks"
package_version="$(tr -d '\r\n' < "$package_root/VERSION")"
"${quota_free_env[@]}" "$packaged_binary" --version | grep -Fx "garnish $package_version"
"${quota_free_env[@]}" "$packaged_binary" --help | grep -F 'Harness Garnish local control plane'

acceptance_step="hermetic temporary Git fixture setup"
echo "fixture: initializing hermetic temporary Git repository"
fixture_repository="$test_root/repository"
fixture_state="$test_root/state"
"${fixture_git[@]}" init -q --template= --initial-branch=main "$fixture_repository"
"${fixture_git[@]}" -C "$fixture_repository" config user.email fixture@example.invalid
"${fixture_git[@]}" -C "$fixture_repository" config user.name Fixture
"${fixture_git[@]}" -C "$fixture_repository" config commit.gpgsign false
"${fixture_git[@]}" -C "$fixture_repository" config core.hooksPath /dev/null
"${fixture_git[@]}" -C "$fixture_repository" config core.autocrlf false
"${fixture_git[@]}" -C "$fixture_repository" config core.fsmonitor false
printf 'fixture\n' > "$fixture_repository/README.md"
"${fixture_git[@]}" -C "$fixture_repository" add README.md
"${fixture_git[@]}" -C "$fixture_repository" commit -q -m fixture
source_head="$("${fixture_git[@]}" -C "$fixture_repository" rev-parse HEAD)"
source_status="$("${fixture_git[@]}" -C "$fixture_repository" status --porcelain=v1 --untracked-files=all)"
if [[ -n "$source_status" ]]; then
  echo "error: temporary source fixture was not clean before Garnish registration" >&2
  printf '%s\n' "$source_status" >&2
  exit 1
fi

acceptance_step="packaged binary fixture initialization"
echo "fixture: initializing packaged Garnish state"
"${quota_free_env[@]}" "$packaged_binary" --data-dir "$fixture_state" init >/dev/null
"${quota_free_env[@]}" "$packaged_binary" --data-dir "$fixture_state" \
  project add --slug package-test --title 'Package test' --path "$fixture_repository" >/dev/null
"${quota_free_env[@]}" "$packaged_binary" --data-dir "$fixture_state" \
  quota set --provider fake --account test --surface five_hour --remaining-percent 90 >/dev/null

task_json="$("${quota_free_env[@]}" "$packaged_binary" --data-dir "$fixture_state" \
  task add --project package-test --title 'Packaged fixture' --goal 'Create result.txt' \
  --accept 'result.txt contains done' --verify-argv '["grep","-qx","done","result.txt"]' \
  --scope result.txt --non-scope 'all other files; Git integration' --risk-class 1 \
  --fake-write-path result.txt --fake-write-content done)"
task_id="$(printf '%s\n' "$task_json" | sed -n 's/.*"id": "\([^"]*\)".*/\1/p' | head -1)"
if [[ -z "$task_id" ]]; then
  echo "error: package test could not read the task ID" >&2
  exit 1
fi

acceptance_step="packaged binary readiness decision"
readiness_json="$("${quota_free_env[@]}" "$packaged_binary" --data-dir "$fixture_state" \
  task readiness "$task_id" --adapter fake --provider fake --account test)"
printf '%s\n' "$readiness_json" | grep -F '"allowed": true' >/dev/null

acceptance_step="packaged binary implementation and detached review"
echo "fixture: executing quota-free packaged task and detached verifier"
"${quota_free_env[@]}" "$packaged_binary" --data-dir "$fixture_state" \
  task run "$task_id" --adapter fake --provider fake --account test >/dev/null
review_json="$("${quota_free_env[@]}" "$packaged_binary" --data-dir "$fixture_state" task review "$task_id")"
printf '%s\n' "$review_json" | grep -F '"status": "review"' >/dev/null
printf '%s\n' "$review_json" | grep -F '"passed": true' >/dev/null
printf '%s\n' "$review_json" | grep -F '"integration_authorized": false' >/dev/null
printf '%s\n' "$review_json" | grep -F '"result.txt"' >/dev/null

acceptance_step="source immutability and private state verification"
final_source_head="$("${fixture_git[@]}" -C "$fixture_repository" rev-parse HEAD)"
if [[ "$final_source_head" != "$source_head" ]]; then
  printf 'error: source fixture HEAD changed: before=%s after=%s\n' \
    "$source_head" "$final_source_head" >&2
  exit 1
fi
final_source_status="$("${fixture_git[@]}" -C "$fixture_repository" status --porcelain=v1 --untracked-files=all)"
if ! "${fixture_git[@]}" -C "$fixture_repository" diff --quiet --; then
  echo "error: Garnish changed a tracked file in the registered source fixture" >&2
  exit 1
fi
if ! "${fixture_git[@]}" -C "$fixture_repository" diff --cached --quiet --; then
  echo "error: Garnish staged a change in the registered source fixture" >&2
  exit 1
fi
if [[ -z "$final_source_status" ]]; then
  echo "error: expected Garnish project projections were not created" >&2
  exit 1
fi
while IFS= read -r status_line; do
  if [[ "$status_line" != "?? .harness-garnish/"* ]]; then
    echo "error: source fixture change escaped the .harness-garnish projection boundary" >&2
    printf '%s\n' "$status_line" >&2
    exit 1
  fi
done <<< "$final_source_status"
for required_projection in PROJECT.md TASKS.md HANDOFF.md; do
  if [[ ! -f "$fixture_repository/.harness-garnish/$required_projection" ]]; then
    echo "error: required project projection is missing: $required_projection" >&2
    exit 1
  fi
done
if [[ -e "$fixture_repository/result.txt" ]]; then
  echo "error: result.txt was written to the registered source fixture" >&2
  exit 1
fi

if [[ "$(uname -s)" == "Darwin" ]]; then
  state_mode="$(stat -f '%Lp' "$fixture_state")"
  database_mode="$(stat -f '%Lp' "$fixture_state/state.db")"
else
  state_mode="$(stat -c '%a' "$fixture_state")"
  database_mode="$(stat -c '%a' "$fixture_state/state.db")"
fi
echo "fixture: observed state permissions directory=$state_mode database=$database_mode"
if [[ "$state_mode" != "700" ]]; then
  echo "error: packaged Garnish state directory mode must be 700, observed $state_mode" >&2
  exit 1
fi
if [[ "$database_mode" != "600" ]]; then
  echo "error: packaged Garnish database mode must be 600, observed $database_mode" >&2
  exit 1
fi

echo "packaged binary: garnish $package_version"
echo "repeated package checksum: deterministic"
echo "state permissions: directory=$state_mode database=$database_mode"
echo "fixture result: review passed; source HEAD/tracked files unchanged; projections confined; integration unauthorized"
echo "Packaged CLI acceptance passed"
