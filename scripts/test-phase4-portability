#!/usr/bin/env bash
set -euo pipefail

if [[ "$(uname -s)" != "Linux" ]]; then
  echo "error: this Phase 4 checkpoint must run on Linux or inside WSL2" >&2
  exit 1
fi

if [[ "$(id -u)" == "0" ]]; then
  echo "error: run this checkpoint as the dedicated non-root user" >&2
  exit 1
fi

kernel_release="$(uname -r)"
platform="linux"
if [[ -n "${WSL_INTEROP:-}" || -n "${WSL_DISTRO_NAME:-}" || "${kernel_release,,}" == *microsoft* ]]; then
  platform="wsl2"
  case "$(pwd -P)" in
    /mnt/[a-zA-Z]/*)
      echo "error: run from a clone in the WSL2 Linux filesystem, not /mnt/<drive>" >&2
      exit 1
      ;;
  esac
fi

echo "phase4 platform: $platform"
echo "kernel: $(uname -srmo)"
echo "rustc: $(rustc --version)"
echo "cargo: $(cargo --version)"
echo "provider credentials: removed from the test process environment"

cargo fmt --check
env -u OPENAI_API_KEY -u ANTHROPIC_API_KEY -u ANTHROPIC_AUTH_TOKEN \
  cargo clippy --locked --workspace --all-targets -- -D warnings
env -u OPENAI_API_KEY -u ANTHROPIC_API_KEY -u ANTHROPIC_AUTH_TOKEN \
  cargo test --locked --workspace

echo "Phase 4 quota-free portability checkpoint passed on $platform"
