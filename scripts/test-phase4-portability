#!/usr/bin/env bash
set -euo pipefail

if [[ "$(uname -s)" != "Linux" ]]; then
  echo "error: this Phase 4 checkpoint must run on Linux or inside WSL2" >&2
  exit 1
fi

if [[ "$(id -u)" == "0" ]]; then
  echo "error: run this checkpoint as the dedicated non-root user" >&2
  exit 1
fi

kernel_release="$(uname -r)"
platform="linux"
if [[ -n "${WSL_INTEROP:-}" || -n "${WSL_DISTRO_NAME:-}" || "${kernel_release,,}" == *microsoft* ]]; then
  platform="wsl2"
  case "$(pwd -P)" in
    /mnt/[a-zA-Z]/*)
      echo "error: run from a clone in the WSL2 Linux filesystem, not /mnt/<drive>" >&2
      exit 1
      ;;
  esac
fi

echo "phase4 platform: $platform"
echo "kernel: $(uname -srmo)"
echo "rustc: $(rustc --version)"
echo "cargo: $(cargo --version)"
echo "provider credentials and live-test acknowledgements: removed from the test process environment"

quota_free_env=(
  env
  -u OPENAI_API_KEY
  -u ANTHROPIC_API_KEY
  -u ANTHROPIC_AUTH_TOKEN
  -u GARNISH_DATA_DIR
  -u GARNISH_REAL_API_PROVIDER
  -u GARNISH_REAL_API_MODEL
  -u GARNISH_REAL_API_SECRET_REFERENCE
  -u GARNISH_ACKNOWLEDGE_PAID_API
  -u GARNISH_ACKNOWLEDGE_PAID_API_PATCH
  -u GARNISH_API_SMOKE_RECEIPT_DIR
  -u GARNISH_REAL_CODEX_REMAINING_PERCENT
  -u GARNISH_ACKNOWLEDGE_CODEX_SUBSCRIPTION
  -u GARNISH_CODEX_SMOKE_RECEIPT_DIR
  -u GARNISH_REAL_DOCKER_IMAGE
  -u GARNISH_REAL_PODMAN_IMAGE
)

./scripts/check-command-placeholders
cargo fmt --all -- --check
"${quota_free_env[@]}" cargo clippy --locked --workspace --all-targets -- -D warnings
"${quota_free_env[@]}" cargo test --locked --workspace

echo "Phase 4 quota-free portability checkpoint passed on $platform"
